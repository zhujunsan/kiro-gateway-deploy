name = "kiro-provision"
main = "src/index.js"
compatibility_date = "2025-01-01"

# 自定义域名：把 Worker 绑到你自己的 zone 的子域名，而不是用默认 *.workers.dev。
# custom_domain = true 时，wrangler 会自动在该 zone 里建好
# 路由和代理 DNS 记录（前提是该 zone 已在当前 Cloudflare 账号下）。
[[routes]]
pattern = "kiro-gateway-provision.example.com"
custom_domain = true

# 遥测用 D1 数据库（设计文档第十三节）。先 `wrangler d1 create kiro-telemetry`，
# 把输出的 database_id 填到下面，再 `wrangler d1 execute kiro-telemetry --remote --file=./schema.sql` 建表。
[[d1_databases]]
binding = "TELEMETRY_DB"
database_name = "kiro-telemetry"
database_id = "<wrangler d1 create 输出的 id>"

# Cron Trigger：每小时把 usage_rollup 卷成 usage_daily（错峰到第 7 分钟）；
# 同时执行闲置隧道清理（仅当 IDLE_CLEANUP_DAYS 配置时生效）。
[triggers]
crons = ["7 * * * *"]

# Workers Logs（可选）：便于排查 provision / usage telemetry 的 Worker 自身问题。
# 网关失败请求抓包已改走 Sentry，不再依赖此处落盘。
[observability]
enabled = true
head_sampling_rate = 1

[observability.logs]
invocation_logs = false

# 可选：闲置隧道清理频率（天）。设为正整数后 cron 自动清理超过该天数未连接的隧道。
# 未配置则不清理。可通过 wrangler secret put IDLE_CLEANUP_DAYS 设置，也可放在 [vars] 里。
# [vars]
# IDLE_CLEANUP_DAYS = "30"
