PROFILE_ARN=arn:aws:codewhisperer:us-east-1:000000000000:profile/XXXXXXXXXXXX
PROXY_API_KEY=change-me

# --- Cloudflare Tunnel ---
CLOUDFLARED_TOKEN=your-cloudflared-tunnel-token

# Optional, defaults shown
# KIRO_GATEWAY_PORT=18000
# KIRO_API_REGION=us-east-1
# TUNNEL_TRANSPORT_PROTOCOL=http2

# --- 针对 Cursor 的优化项（已填最优默认值，开箱即用）---
# Cursor 的 Agent 模式会带大量工具定义 + 长上下文，下面几个是针对性调过的。

# 伪推理（注入 thinking 标签让模型吐思考过程）。上游默认开启（true）。
# 关掉可省输出 token、响应更快。compose 里默认已设为 false。
# 可选值：false / 0 / no / disabled / off 关闭；其余值或留空为开启。
FAKE_REASONING=false

# 自动裁剪超大 payload。Cursor 很容易撞到 Kiro API ~615KB 上限报
# "Improperly formed request"，开启后从最老的历史开始裁直到放得下。
# 上游默认 false，这里设为 true。
AUTO_TRIM_PAYLOAD=true
# 触发自动裁剪的字节阈值（留 15KB 安全余量）。
KIRO_MAX_PAYLOAD_BYTES=600000

# 上游流式中途截断时，让模型自感知并改写更小的输出。
TRUNCATION_RECOVERY=true

# 关掉自动注入的 web_search 工具。Cursor 自己管理工具集，多塞一个可能
# 干扰 tool calling。上游默认 true，这里设为 false。
WEB_SEARCH_ENABLED=false

# 首 token 超时（秒）。带大上下文时首 token 容易慢，上游默认 15s 偏短，
# 这里调到 30s，避免被过早掐断重试。
FIRST_TOKEN_TIMEOUT=30
# 首 token 超时后的最大重试次数。
FIRST_TOKEN_MAX_RETRIES=3
# 流式分块之间的读超时（秒）。复杂 tool call 思考间隔久时可调大。
STREAMING_READ_TIMEOUT=300

# --- 其他可选（按需开启）---
# 多账号自动 failover（429/402 时切号）。单账号也能开，但只有多号才有意义。
# ACCOUNT_SYSTEM=false
# 日志级别：TRACE/DEBUG/INFO/WARNING/ERROR/CRITICAL。排查时设 DEBUG。
# LOG_LEVEL=INFO
# 调试日志：off（默认）/ errors（只记失败请求，排查报错很有用）/ all。
# DEBUG_MODE=off
